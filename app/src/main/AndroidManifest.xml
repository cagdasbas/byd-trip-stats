<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- External storage — backup/restore database to Download/BydTripStats -->
    <!-- Up to 32: needed to read backups from shared storage (Download/SD) on legacy storage,
         including DiLink-5 head units (Android 11/12) and backups that survived an uninstall.
         READ_EXTERNAL_STORAGE is replaced by granular media perms on API 33+, which don't cover
         arbitrary .db files; no head units run 33+ yet. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Up to 32: same legacy-storage reason as READ above — needed to WRITE backups to shared
         storage (SD card) and delete filesystem backups on DiLink-5 head units (Android 11/12). -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    
    <!-- Foreground service -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Permissions for boot and autostart -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- System permissions -->
    <uses-permission android:name="android.permission.BYD" />
    <uses-permission android:name="android.permission.DEVICE_ACC" />
    <uses-permission android:name="android.permission.DEVICE_POWER" />
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_SET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.READ_LOGS" />

    <!-- BYD DiLink permissions -->
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_ENERGY_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_AC_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_AC_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_CHARGING_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_BIGDATA_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_MOTOR_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_MOTOR_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_LOCATION_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_GEARBOX_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_POWER_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_BATTERY_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_ENGINE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_OTA_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_OTA_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_DTC_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_SETTING_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_STATISTIC_GET" />
    <!-- DiLink-5: getInstance enforces *_COMMON server-side. STATISTIC_COMMON is `dangerous` on D5
         (declare here; grant once via `adb shell pm grant com.byd.tripstats
         android.permission.BYDAUTO_STATISTIC_COMMON`). CHARGING/SPEED_COMMON are normal (auto).
         VEHICLEHEALTH_* = SOH. Harmless extra declarations on DiLink-3. -->
    <uses-permission android:name="android.permission.BYDAUTO_STATISTIC_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_CHARGING_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_VEHICLEHEALTH_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_VEHICLEHEALTH_COMMON" />
    <uses-permission android:name="android.permission.BYDAUTO_SENSOR_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_MQTT_GET" />
    <uses-permission android:name="android.permission.BYDAUTO_TEST_GET" />
    <!-- Signal device — raw CAN data -->
    <uses-permission android:name="android.permission.BYDAUTO_SIGNAL_GET" />
    <!-- BMS device -->
    <uses-permission android:name="android.permission.BYDAUTO_BMS_GET" />

     <!-- Permissions for autoupdates -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- DiLink-5 SDK injection prototype: needed to query com.byd.data.collect's apk path
         (Android 11+ package visibility). -->
    <queries>
        <package android:name="com.byd.data.collect" />
    </queries>

    <application
        android:name=".BydStatsApplication"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BydTripStats"
        android:requestLegacyExternalStorage="true">
        
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|density"
            android:theme="@style/Theme.BydTripStats">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Vehicle telemetry service -->
        <service
            android:name=".service.VehicleTelemetryService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="dataSync|location"
            android:stopWithTask="false" />

        <service
            android:name=".service.ServiceRestarterJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true" />

        <!-- Boot Receiver - Auto-start on car boot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.REBOOT" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
                <action android:name="android.intent.action.SCREEN_ON" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.byd.action.ACC_ON" />
                <action android:name="com.byd.action.ACC_OFF" />
                <action android:name="com.byd.action.IGN_ON" />
                <action android:name="com.byd.accmode.ACC_MODE_CHANGED" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.POWER_CONNECTED" />
                <action android:name="android.intent.action.POWER_DISCONNECTED" />
            </intent-filter>
        </receiver>

        <!-- Off-state keepalive: 90-minute alarm chain after ACC_OFF. This is the
             ONLY reliable wake-up for off-state EV charging: android.intent.action
             .POWER_CONNECTED tracks the head unit's own 12V/USB power, not the
             traction battery being plugged into an AC/DC charger, so it does not
             fire when an EV starts charging while parked. The alarm therefore
             bounds a missed off-state charge session to at most ~90 min late (in
             Minimal mode). Not scheduled in Deep Sleep mode — off-state charging is
             then only reconstructed from the SoC delta on the next ACC_ON. Survives
             process death via AlarmManager RTC_WAKEUP. -->
        <receiver
            android:name=".receiver.OffStateKeepaliveReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.byd.tripstats.action.OFF_STATE_KEEPALIVE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ServiceRestartReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Receives PackageInstaller session results for silent self-update -->
        <receiver
            android:name=".receiver.InstallStatusReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.byd.tripstats.action.INSTALL_STATUS" />
            </intent-filter>
        </receiver>

        <!-- Disable WorkManagerInitializer from androidx.startup so WorkManager
             can be initialized manually via Configuration.Provider in BydStatsApplication.
             Without this the app crashes with "WorkManager is already initialized". -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Fileprovider - for autoupdate -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>